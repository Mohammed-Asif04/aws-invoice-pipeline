# ============================================================================
# AWS Invoice Processing Pipeline — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ---------------------------------------------------------------------------
# AWS General
# ---------------------------------------------------------------------------
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012
AWS_PROFILE=default

# ---------------------------------------------------------------------------
# S3 Buckets
# ---------------------------------------------------------------------------
RAW_BUCKET=invoice-pipeline-raw
AUDIT_BUCKET=invoice-pipeline-audit

# ---------------------------------------------------------------------------
# DynamoDB Tables
# ---------------------------------------------------------------------------
INVOICE_TABLE=InvoiceRecords
AUDIT_TABLE=AuditEntries

# ---------------------------------------------------------------------------
# Step Functions
# ---------------------------------------------------------------------------
STATE_MACHINE_ARN=arn:aws:states:ap-south-1:123456789012:stateMachine:InvoicePipelineStateMachine

# ---------------------------------------------------------------------------
# Amazon Bedrock (Claude)
# ---------------------------------------------------------------------------
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
CONFIDENCE_THRESHOLD=85

# ---------------------------------------------------------------------------
# Amazon SES (Email)
# ---------------------------------------------------------------------------
SES_SENDER_EMAIL=noreply@yourdomain.com
SES_REGION=ap-south-1

# ---------------------------------------------------------------------------
# Amazon SNS (Notifications)
# ---------------------------------------------------------------------------
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:InvoicePipelineNotifications

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
APPROVAL_API_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod
REVIEWER_EMAIL=reviewer@yourdomain.com

# ---------------------------------------------------------------------------
# AWS SAM Deployment
# ---------------------------------------------------------------------------
SAM_STACK_NAME=aws-invoice-pipeline
SAM_S3_BUCKET=aws-sam-cli-managed-default-samclisourcebucket-xxxxxxxxxxxx
SAM_REGION=ap-south-1

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod
VITE_APP_NAME=Invoice Pipeline
VITE_AWS_REGION=ap-south-1

# ---------------------------------------------------------------------------
# Secrets Manager (secret names, not actual values)
# ---------------------------------------------------------------------------
SECRETS_API_KEYS=invoice-pipeline/api-keys
SECRETS_DB_CREDENTIALS=invoice-pipeline/db-credentials
