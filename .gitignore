# ============================================================================
# AWS Invoice Processing Pipeline — Git Ignore
# ============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log

# ---------------------------------------------------------------------------
# Build Outputs
# ---------------------------------------------------------------------------
dist/
dist-ssr/
build/
.next/
out/
*.js.map
*.d.ts.map

# Backend Lambda build artifacts
backend/lambdas/**/dist/
backend/lambdas/**/*.js
backend/lambdas/**/*.d.ts
!backend/lambdas/**/package.json
!backend/lambdas/**/tsconfig.json

# ---------------------------------------------------------------------------
# Environment & Secrets (CRITICAL — never commit)
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
.aws-sam/
samconfig.toml
*.pem
*.key
cdk.out/
cdk.context.json

# ---------------------------------------------------------------------------
# IDE & Editor
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.local
*.tsbuildinfo
.eslintcache
.cache/
tmp/
temp/
